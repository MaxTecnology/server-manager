{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=./data/sessionmanager.db"
  },
  "Jwt": {
    "Issuer": "SessionManager",
    "Audience": "SessionManager.Internal",
    "SigningKey": "CHANGE_THIS_KEY_WITH_32_PLUS_CHARACTERS",
    "ExpirationMinutes": 480
  },
  "AdminSeed": {
    "Username": "admin",
    "DisplayName": "Administrador",
    "Password": "Admin@12345"
  },
  "WindowsSession": {
    "CommandTimeoutSeconds": 15
  },
  "Agent": {
    "ApiKey": "CHANGE_THIS_AGENT_API_KEY"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
