# Postgres
POSTGRES_DB=sessionmanager
POSTGRES_USER=sessionmanager
POSTGRES_PASSWORD=CHANGE_THIS_DB_PASSWORD

# Host ports (ajuste se ja houver servico ocupando 5000/8080)
SESSIONMANAGER_API_PORT=5000
SESSIONMANAGER_FRONT_PORT=8080

# API security
SESSIONMANAGER_JWT_SIGNING_KEY=CHANGE_THIS_KEY_WITH_32_PLUS_CHARACTERS
SESSIONMANAGER_ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD
SESSIONMANAGER_AGENT_API_KEY=CHANGE_THIS_AGENT_API_KEY

# CORS and frontend
SESSIONMANAGER_CORS_ORIGIN=https://app.seu-dominio.com
SESSIONMANAGER_FRONT_API_BASE_URL=https://api.seu-dominio.com
